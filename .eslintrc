{
  "extends": "airbnb-base",
  "rules": {
    "no-underscore-dangle": ["error", { "allow": ["_id"] }],
    "no-console": "off",
    "linebreak-style": "off",
    "no-unused-vars": ["error", { "argsIgnorePattern": "next" }],
  },
  "env": {
    "node": true,
    "commonjs": true,
    "es2021": true,
  },
}
